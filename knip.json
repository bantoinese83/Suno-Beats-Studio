{
  "$schema": "https://unpkg.com/knip@next/schema.json",
  "project": ["**/*.ts", "**/*.tsx"],
  "entry": ["src/app/**/*.{ts,tsx}", "src/middleware.ts", "next.config.js"],
  "ignore": ["**/*.test.ts"],
  "ignoreDependencies": ["@types/node", "@types/react", "@types/react-dom"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "error",
    "types": "error",
    "duplicates": "error"
  }
}
